[Unit]
Description=Expoin treasury bonus API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=expoin-bonus
Group=expoin-bonus
WorkingDirectory=/opt/expoin-bonus
EnvironmentFile=/opt/expoin-bonus/.env
ExecStart=/usr/bin/node /opt/expoin-bonus/index.mjs
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/expoin-bonus

[Install]
WantedBy=multi-user.target
